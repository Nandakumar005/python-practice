   "source": [
    "string=\"BANANA\"\n",
    "length=len(string)\n",
    "vowels=\"AEIOU\"\n",
    "kevin_score=0\n",
    "stuart_score=0\n",
    "for i in range(length):\n",
    "    if string[i] in vowels:\n",
    "        kevin_score+=length-i\n",
    "    else:\n",
    "        stuart_score+=length-i\n",
    "\n",
    "print(\"Kevin's score:\", kevin_score)\n",
    "print(\"Stuart's score:\", stuart_score)"
   ]
  }
 ],
